# LLM Configuration
# Compatible with any OpenAI-format API (OpenAI, DeepSeek, Claude via proxy, etc.)
OPENAI_BASE_URL="https://api.deepseek.com/v1"
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_MODEL="deepseek-chat"

# Database (SQLite by default, no setup required)
DATABASE_URL="sqlite:///./yuri_os.db"

# CORS — comma-separated list of allowed origins for the frontend.
# Use "*" only for local development. In production, list exact origins.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3121,http://127.0.0.1:3000,http://127.0.0.1:3121"
